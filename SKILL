### 2A.2 fMRI 预处理流水线

```python
# ============================================================
# 模块：fMRI 静息态预处理 + 功能连接矩阵
# 依赖：nilearn, nibabel, numpy, matplotlib
# ============================================================
import numpy as np
import matplotlib.pyplot as plt
from nilearn import datasets, image, signal, connectome
from nilearn.maskers import NiftiLabelsMasker
from nilearn.plotting import plot_matrix, plot_connectome

# ------ 1. 加载示例数据（替换为真实路径）------
dataset    = datasets.fetch_development_fmri(n_subjects=1)
fmri_img   = dataset.func[0]
confounds  = dataset.confounds[0]

# ------ 2. 图谱选择（AAL / Schaefer / Destrieux）------
atlas = datasets.fetch_atlas_aal(version="SPM12")
atlas_img    = atlas.maps
atlas_labels = atlas.labels

# ------ 3. 信号提取 ------
masker = NiftiLabelsMasker(
    labels_img=atlas_img,
    standardize=True,
    memory="nilearn_cache",
    verbose=0,
    detrend=True,
    low_pass=0.1,
    high_pass=0.01,
    t_r=2.0          # 替换为实际 TR（秒）
)
time_series = masker.fit_transform(fmri_img, confounds=confounds)

# ------ 4. 功能连接矩阵 ------
correlation_measure = connectome.ConnectivityMeasure(
    kind="correlation"  # 可选: "partial correlation", "tangent"
)
conn_matrix = correlation_measure.fit_transform([time_series])[0]

# ------ 5. 可视化 ------
fig, axes = plt.subplots(1, 2, figsize=(16, 6))

# 热力图
plot_matrix(
    conn_matrix,
    labels=atlas_labels,
    colorbar=True,
    vmax=0.8,
    vmin=-0.8,
    title="功能连接矩阵 (AAL-90)",
    axes=axes[0]
)

# 连接组图
coords = atlas.region_coords
plot_connectome(
    conn_matrix,
    coords,
    edge_threshold="90%",
    title="Top 10% 功能连接",
    display_mode="ortho",
    axes=axes[1]
)

plt.tight_layout()
plt.savefig("functional_connectivity.png", dpi=150)
print("已保存: functional_connectivity.png")
```

