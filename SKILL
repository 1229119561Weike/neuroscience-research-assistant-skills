### 2B.2 EEG 预处理流水线

```python
# ============================================================
# 模块：EEG 预处理 + 时频分析
# 依赖：mne, numpy, matplotlib
# ============================================================
import mne
import numpy as np
import matplotlib.pyplot as plt

# ------ 1. 数据加载 ------
# 支持格式：.fif / .edf / .bdf / .set (EEGLAB) / .vhdr (BrainVision)
raw = mne.io.read_raw_fif("sample_raw.fif", preload=True, verbose=False)
# 对于 EDF：raw = mne.io.read_raw_edf("data.edf", preload=True)

print(raw.info)
print(f"采样率: {raw.info['sfreq']} Hz")
print(f"通道数: {len(raw.ch_names)}")

# ------ 2. 预处理流水线 ------
# 2.1 带通滤波（0.1–40 Hz）
raw.filter(l_freq=0.1, h_freq=40.0, fir_design="firwin")

# 2.2 陷波滤波（去工频干扰）
raw.notch_filter(freqs=[50, 100])  # 欧洲用 50 Hz，美国用 60 Hz

# 2.3 坏导标注 & 插值
raw.plot(n_channels=30, title="原始数据检查")
raw.interpolate_bads(reset_bads=True)

# 2.4 重参考（平均参考）
raw.set_eeg_reference("average", projection=True)
raw.apply_proj()

# 2.5 ICA 去伪迹（眼电、心电）
from mne.preprocessing import ICA
ica = ICA(n_components=20, random_state=97, max_iter="auto")
ica.fit(raw)
ica.plot_components()
# 手动标注或自动检测 EOG 伪迹
eog_indices, eog_scores = ica.find_bads_eog(raw)
ica.exclude = eog_indices
raw_clean = ica.apply(raw.copy())

# ------ 3. Epoch 切分 ------
events, event_id = mne.events_from_annotations(raw_clean)
epochs = mne.Epochs(
    raw_clean,
    events,
    event_id=event_id,
    tmin=-0.2,
    tmax=0.8,
    baseline=(-0.2, 0),
    reject={"eeg": 100e-6},  # 100 μV 阈值拒绝
    preload=True
)
print(f"保留 Epoch: {len(epochs)}")

# ------ 4. 时频分析（Morlet 小波）------
from mne.time_frequency import tfr_morlet

freqs  = np.logspace(np.log10(4), np.log10(40), 20)  # 4–40 Hz
n_cycles = freqs / 2.0  # 自适应周期数

power, itc = tfr_morlet(
    epochs,
    freqs=freqs,
    n_cycles=n_cycles,
    return_itc=True,
    average=True
)

# ------ 5. 可视化 ------
power.plot(
    picks=["Cz"],
    baseline=(-0.2, 0),
    mode="logratio",
    title="时频功率谱 (Cz 电极)",
    cmap="RdBu_r"
)
plt.savefig("tfr_power.png", dpi=150)
print("已保存: tfr_power.png")
```

