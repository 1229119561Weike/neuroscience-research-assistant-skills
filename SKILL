## §1 文献挖掘（Literature Mining）

### 1.1 PubMed API 调用逻辑

```python
# ============================================================
# 模块：PubMed 自动化文献检索
# 依赖：requests, xml.etree.ElementTree, pandas
# ============================================================
import requests
import xml.etree.ElementTree as ET
import pandas as pd
from time import sleep

PUBMED_ESEARCH = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi"
PUBMED_EFETCH  = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi"

def search_pubmed(query: str, max_results: int = 20) -> list[str]:
    """
    在 PubMed 上搜索，返回 PMID 列表。
    示例 query: "hippocampus memory fMRI[Title/Abstract]"
    """
    params = {
        "db": "pubmed",
        "term": query,
        "retmax": max_results,
        "retmode": "json",
        "sort": "relevance"
    }
    response = requests.get(PUBMED_ESEARCH, params=params)
    response.raise_for_status()
    pmids = response.json()["esearchresult"]["idlist"]
    return pmids

def fetch_abstracts(pmids: list[str]) -> pd.DataFrame:
    """
    批量获取摘要，返回结构化 DataFrame。
    列：pmid | title | abstract | authors | year | journal
    """
    records = []
    for pmid in pmids:
        sleep(0.34)  # NCBI 速率限制：3 req/s
        params = {
            "db": "pubmed",
            "id": pmid,
            "rettype": "xml",
            "retmode": "xml"
        }
        resp = requests.get(PUBMED_EFETCH, params=params)
        root = ET.fromstring(resp.content)
        article = root.find(".//PubmedArticle")
        if article is None:
            continue

        title    = article.findtext(".//ArticleTitle", default="N/A")
        abstract = " ".join(t.text or "" for t in article.findall(".//AbstractText"))
        year     = article.findtext(".//PubDate/Year", default="N/A")
        journal  = article.findtext(".//Journal/Title", default="N/A")
        authors  = [
            f"{a.findtext('LastName', '')} {a.findtext('ForeName', '')}".strip()
            for a in article.findall(".//Author")[:3]
        ]
        records.append({
            "pmid": pmid,
            "title": title,
            "abstract": abstract,
            "authors": "; ".join(authors),
            "year": year,
            "journal": journal
        })
    return pd.DataFrame(records)


# ---- 使用示例 ----
if __name__ == "__main__":
    pmids = search_pubmed(
        query="hippocampus memory encoding fMRI[Title/Abstract]",
        max_results=10
    )
    df = fetch_abstracts(pmids)
    df.to_csv("pubmed_results.csv", index=False)
    print(df[["pmid", "title", "year", "journal"]].to_markdown())
```

### 1.2 脑区相关性提取（NLP Pipeline）

```python
# ============================================================
# 模块：基于关键词的脑区相关性提取
# 依赖：spacy, collections
# 安装：pip install spacy && python -m spacy download en_core_web_sm
# ============================================================
import spacy
from collections import Counter
import re

# 预定义脑区词典（可扩展）
BRAIN_REGIONS = [
    "hippocampus", "amygdala", "prefrontal cortex", "anterior cingulate",
    "thalamus", "cerebellum", "insula", "basal ganglia", "putamen",
    "caudate nucleus", "nucleus accumbens", "orbitofrontal cortex",
    "dorsolateral prefrontal cortex", "ventromedial prefrontal cortex",
    "parahippocampal gyrus", "entorhinal cortex", "fusiform gyrus",
    "superior temporal sulcus", "motor cortex", "somatosensory cortex",
    "visual cortex", "auditory cortex", "Broca's area", "Wernicke's area"
]

nlp = spacy.load("en_core_web_sm")

def extract_brain_region_cooccurrence(abstracts: list[str]) -> pd.DataFrame:
    """
    从摘要列表中提取脑区共现关系。
    返回 DataFrame：region_a | region_b | co_count
    """
    from itertools import combinations
    pairs = Counter()

    for text in abstracts:
        text_lower = text.lower()
        found = [r for r in BRAIN_REGIONS if r in text_lower]
        for pair in combinations(sorted(set(found)), 2):
            pairs[pair] += 1

    rows = [{"region_a": a, "region_b": b, "co_count": c}
            for (a, b), c in pairs.most_common(50)]
    return pd.DataFrame(rows)
```

