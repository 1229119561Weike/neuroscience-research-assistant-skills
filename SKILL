### 3.2 TVB 全脑网络模型流水线

```python
# ============================================================
# 模块：TVB 全脑动力学模拟
# 依赖：tvb, numpy, matplotlib
# 参考：https://www.thevirtualbrain.org/tvb/zwei
# ============================================================
import numpy as np
import matplotlib.pyplot as plt
from tvb.simulator.lab import (
    simulator, models, coupling, integrators,
    monitors, connectivity
)

# ------ 1. 加载结构连接矩阵 ------
# 使用 TVB 内置图谱（76 节点 Hagmann 连接组）
conn = connectivity.Connectivity.from_file()
conn.speed = np.array([4.0])   # 传导速度 (m/s)
conn.configure()

print(f"节点数: {conn.number_of_regions}")
print(f"区域标签: {conn.region_labels[:5]}")

# ------ 2. 神经质量模型选择 ------
# 选项：Wilson-Cowan / Kuramoto / Hindmarsh-Rose / Generic2dOscillator
neural_model = models.WilsonCowan(
    c_ee=np.array([16.0]),   # E-E 连接权重
    c_ei=np.array([12.0]),   # E-I 连接权重
    c_ie=np.array([15.0]),   # I-E 连接权重
    c_ii=np.array([3.0]),    # I-I 连接权重
    tau_e=np.array([10.0]),  # 兴奋性时间常数 (ms)
    tau_i=np.array([20.0])   # 抑制性时间常数 (ms)
)

# ------ 3. 全局耦合函数 ------
coupl = coupling.Linear(a=np.array([0.0154]))

# ------ 4. 数值积分器 ------
integ = integrators.HeunStochastic(
    dt=0.05,                              # 积分步长 (ms)
    noise=noise.Additive(nsig=np.array([0.01]))  # 加性高斯噪声
)

# ------ 5. 监测器（模拟 BOLD / LFP）------
mon_tavg = monitors.TemporalAverage(period=1.0)   # 时均（模拟 LFP）
mon_bold  = monitors.Bold(period=2000.0)            # BOLD 信号（TR=2s）

# ------ 6. 构建并运行模拟器 ------
sim = simulator.Simulator(
    model=neural_model,
    connectivity=conn,
    coupling=coupl,
    integrator=integ,
    monitors=(mon_tavg, mon_bold)
)
sim.configure()

# 运行 10 秒模拟
duration_ms = 10000.0
print(f"开始模拟：{duration_ms} ms ...")
(tavg_time, tavg_data), (bold_time, bold_data) = sim.run(simulation_length=duration_ms)

print(f"时均数据形状: {tavg_data.shape}")   # (time, state_vars, nodes, modes)
print(f"BOLD 数据形状: {bold_data.shape}")

# ------ 7. 可视化 ------
fig, axes = plt.subplots(2, 1, figsize=(14, 8))

# 时均信号（前 5 个节点）
axes[0].plot(tavg_time / 1000, tavg_data[:, 0, :5, 0])
axes[0].set_xlabel("时间 (s)")
axes[0].set_ylabel("活动强度")
axes[0].set_title("神经活动时间序列（LFP 代理，前 5 节点）")
axes[0].legend(conn.region_labels[:5])

# BOLD 信号
axes[1].plot(bold_time / 1000, bold_data[:, 0, :5, 0])
axes[1].set_xlabel("时间 (s)")
axes[1].set_ylabel("BOLD 信号")
axes[1].set_title("模拟 BOLD 信号（前 5 节点）")

plt.tight_layout()
plt.savefig("tvb_simulation.png", dpi=150)
print("已保存: tvb_simulation.png")
```

### 3.3 参数扫描协议

```python
# ============================================================
# 模块：参数空间扫描（全局耦合强度 vs 传导速度）
# ============================================================
coupling_strengths = np.linspace(0.01, 0.05, 5)
conduction_speeds  = np.array([3.0, 4.0, 6.0])

results = {}
for speed in conduction_speeds:
    for g in coupling_strengths:
        conn.speed = np.array([speed])
        coupl.a    = np.array([g])
        sim.configure()
        (_, data), _ = sim.run(simulation_length=5000.0)
        # 计算同步指标（Kuramoto 序参量）
        phases   = np.angle(data[:, 0, :, 0])
        r        = np.abs(np.mean(np.exp(1j * phases), axis=1)).mean()
        results[(speed, g)] = r
        print(f"speed={speed:.1f}, g={g:.3f} → R={r:.3f}")
```

### 3.4 参数指导清单

| 参数 | 推荐范围 | 生理意义 |
|------|---------|---------|
| `coupling.a` (全局耦合 G) | 0.008–0.05 | 长程白质纤维传递效率 |
| `conn.speed` | 2–10 m/s | 轴突传导速度 |
| `tau_e` | 5–20 ms | 兴奋性突触时间常数 |
| `tau_i` | 10–40 ms | 抑制性突触时间常数 |
| `nsig` (噪声强度) | 0.001–0.05 | 神经元固有噪声水平 |

