    )
    sns.stripplot(
        data=df, x=region_col, y=value_col,
        hue=group_col, dodge=True,
        alpha=0.4, size=4, ax=ax, legend=False
    )
    ax.set_xlabel("脑区")
    ax.set_ylabel("激活强度 (β)")
    ax.set_title("组间脑区激活比较")
    plt.xticks(rotation=45, ha="right")
    plt.tight_layout()
    fig.savefig(output, dpi=300)
    return fig


def plot_connectivity_circular(conn_matrix: np.ndarray,
                                labels: list[str],
                                output: str = "circular_conn.png"):
    """
    环形功能连接图（仅显示 top 20% 连接）
    依赖：mne-connectivity
    """
    from mne_connectivity.viz import plot_connectivity_circle
    threshold = np.percentile(np.abs(conn_matrix), 80)
    fig, ax = plt.subplots(subplot_kw=dict(polar=True), figsize=(8, 8))
    plot_connectivity_circle(
        conn_matrix,
        node_names=labels,
        n_lines=50,
        vmin=-1.0,
        vmax=1.0,
        colormap="RdBu_r",
        title="功能连接环形图",
        ax=ax
    )
    fig.savefig(output, dpi=150)
    return fig


def plot_tfr_heatmap(times: np.ndarray, freqs: np.ndarray,
                     power: np.ndarray, output: str = "tfr_heatmap.png"):
    """
    时频热力图
    power 形状：(n_freqs, n_times)
    """
    fig, ax = plt.subplots(figsize=(12, 5))
    im = ax.pcolormesh(
        times * 1000, freqs, power,
        cmap="RdBu_r", shading="gouraud"
    )
    ax.set_yscale("log")
    ax.set_xlabel("时间 (ms)")
    ax.set_ylabel("频率 (Hz)")
    ax.set_title("时频功率谱")
    plt.colorbar(im, ax=ax, label="功率 (dB)")
    ax.axvline(x=0, color="k", linestyle="--", linewidth=1.5, label="刺激呈现")
    ax.legend()
    plt.tight_layout()
    fig.savefig(output, dpi=150)
    return fig
